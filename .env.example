# Copy this file to .env.local and fill in your values.
# Generate NEXTAUTH_SECRET with: openssl rand -hex 32

NEXTAUTH_SECRET=replace-with-a-long-random-string
NEXTAUTH_URL=http://YOUR_VPS_IP_OR_DOMAIN

# First owner account — created when you run: npm run seed
OWNER_USERNAME=admin
OWNER_PASSWORD=choose-a-strong-password
OWNER_DISPLAY_NAME=Admin
